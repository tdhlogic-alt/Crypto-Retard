# Example environment variables for local development and CI
# DO NOT commit real secrets. Use GitHub Actions Secrets for production.

# Coinbase API
COINBASE_API_KEY_NAME=organizations/{org_id}/apiKeys/{key_id}
# Paste the PEM on one line with \n escaped, or store as a multiline secret in GitHub
COINBASE_PRIVATE_KEY_PEM='-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----'

# Optional runtime
SPRING_PROFILES_ACTIVE=prod

# Other secrets used by CI (example)
GCP_SA_KEY_B64=

# Notes:
# - Add real secrets in GitHub repo Settings → Secrets → Actions.
# - Never commit private keys or API tokens into git.
